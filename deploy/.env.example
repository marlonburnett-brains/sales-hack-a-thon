# =============================================================================
# Production Environment Variables for Agent Server (Oracle Cloud VM)
# =============================================================================
# Copy this file to .env in the deployment directory and fill in all values.
# NEVER commit the .env file -- it contains secrets.
# =============================================================================

# --- Supabase PostgreSQL (PRODUCTION) ---
# Pooled connection via PgBouncer (port 6543) -- used for runtime queries
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) -- used for migrations and Mastra storage
DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# --- Google Workspace (inline JSON) ---
# Service account credentials for Google Drive, Slides, and Docs APIs
# Format: {"type":"service_account","project_id":"...","private_key":"...","client_email":"...",...}
GOOGLE_SERVICE_ACCOUNT_KEY=
# Google Drive folder ID where generated presentations are stored
GOOGLE_DRIVE_FOLDER_ID=
# Google Slides template presentation ID (Lumenalta branded template)
GOOGLE_TEMPLATE_PRESENTATION_ID=
# Source presentation ID for Touch 2 "Meet Lumenalta" intro deck (optional)
MEET_LUMENALTA_PRESENTATION_ID=
# Source presentation ID for Touch 3 capability alignment deck (optional)
CAPABILITY_DECK_PRESENTATION_ID=

# --- Vertex AI ---
# Service account credentials as inline JSON string.
# env.ts writes this to a temp file and sets GOOGLE_APPLICATION_CREDENTIALS automatically.
VERTEX_SERVICE_ACCOUNT_KEY=
# Google Cloud project ID for Vertex AI
GOOGLE_CLOUD_PROJECT=
# Google Cloud region for Vertex AI (e.g., us-central1)
GOOGLE_CLOUD_LOCATION=us-central1

# --- Server Config ---
NODE_ENV=production
MASTRA_PORT=4111
# Supabase JWT secret for verifying user tokens from the web app
# Found in: Supabase Dashboard -> Settings -> API -> JWT Secret
SUPABASE_JWT_SECRET=
# Web app origin URL for CORS restriction
WEB_APP_URL=https://your-vercel-app.vercel.app

# AES-256-GCM encryption key for Google refresh tokens (64 hex chars = 32 bytes)
# Generate with: openssl rand -hex 32
GOOGLE_TOKEN_ENCRYPTION_KEY=

# --- Caddy ---
# Domain name for the agent server (Caddy auto-obtains TLS certificate)
# Example: agent.yourdomain.com
AGENT_DOMAIN=agent.yourdomain.com
