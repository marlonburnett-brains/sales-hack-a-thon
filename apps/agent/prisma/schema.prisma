generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Application-level job records — Phase 1 only needs WorkflowJob
// Phases 4/5 will add BriefingRequest, TranscriptJob, ApprovalState
model WorkflowJob {
  id        String   @id @default(cuid())
  type      String   // "briefing" | "transcript" | "asset_gen"
  status    String   @default("pending")  // "pending" | "running" | "done" | "failed"
  payload   String   // JSON blob
  result    String?  // JSON blob
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Brand asset registry — curated subset of headshots, logos, icons from Google Drive
// Phase 2 Plan 03: Image registry for slide assembly (Phase 4+)
model ImageAsset {
  id          String   @id @default(cuid())
  category    String   // "headshot" | "logo" | "icon" | "brand_element"
  name        String   // Person name or asset name (e.g., "John Smith", "Lumenalta Logo Primary")
  description String?  // Optional description for search
  driveFileId String   @unique // Google Drive file ID — prevents duplicate entries
  driveUrl    String   // Direct Google Drive URL: https://drive.google.com/file/d/{id}/view
  mimeType    String   // "image/png", "image/jpeg", etc.
  tags        String   // JSON array of tags: ["leadership", "executive"]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([name])
}

// ────────────────────────────────────────────────────────────
// Content source tracking — tracks Drive files/folders and their accessibility
// Discovery pipeline upserts on each run; powers admin dashboard for pending access grants
// ────────────────────────────────────────────────────────────

model ContentSource {
  id            String   @id @default(cuid())
  name          String   @unique // Display name: "Meet Lumenalta", "NBCUniversal", etc.
  sourceType    String   // "presentation" | "folder" | "shared_drive"
  contentType   String?  // "template" | "example" | "case_study" | "brand_guide"
  touchTypes    String?  // JSON array: ["touch_2"], ["touch_3", "touch_4"]
  accessStatus  String   @default("not_accessible") // "accessible" | "not_accessible" | "pending_access"
  driveFileId   String?  // Drive file/folder ID once resolved (null if never discovered)
  driveUrl      String?  // Direct URL if known
  folderPath    String?  // Where it was found in the Drive hierarchy
  lastCheckedAt DateTime? // When discovery last probed this source
  errorMessage  String?  // Last error: "403 Forbidden", "Shortcut target not found", etc.
  slideCount    Int      @default(0) // Number of slides discovered from this source
  ingestedCount Int      @default(0) // Number of slides successfully ingested
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([accessStatus])
  @@index([contentType])
}

// ────────────────────────────────────────────────────────────
// Phase 4: Touch 1-3 Asset Generation & Interaction Tracking
// ────────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(cuid())
  name      String
  industry  String
  logoUrl   String?  // Drive URL or public URL for customer logo
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deals     Deal[]

  @@unique([name])
}

model Deal {
  id               String              @id @default(cuid())
  companyId        String
  company          Company             @relation(fields: [companyId], references: [id])
  name             String              // e.g., "Q1 2026 Enterprise Pitch"
  salespersonName  String?
  salespersonPhoto String?             // Drive file ID or URL
  driveFolderId    String?             // Per-deal folder in shared Drive
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  interactions     InteractionRecord[]

  @@index([companyId])
}

model InteractionRecord {
  id               String            @id @default(cuid())
  dealId           String
  deal             Deal              @relation(fields: [dealId], references: [id])
  touchType        String            // "touch_1" | "touch_2" | "touch_3" | "touch_4"
  status           String            @default("pending") // "pending" | "generating" | "pending_review" | "approved" | "overridden" | "edited"
  inputs           String            // JSON: company, industry, context, etc.
  decision         String?           // "approved" | "overridden" | "edited" | null (if pending)
  generatedContent String?           // JSON: AI-generated content for review
  outputRefs       String?           // JSON array: Drive URLs of generated assets
  driveFileId      String?           // Primary generated presentation ID
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  feedbackSignals  FeedbackSignal[]
  transcript       Transcript?       // 1:1 optional (only for touch_4)
  brief            Brief?            // 1:1 optional (only for touch_4)

  @@index([dealId])
  @@index([touchType])
}

model FeedbackSignal {
  id              String            @id @default(cuid())
  interactionId   String
  interaction     InteractionRecord @relation(fields: [interactionId], references: [id])
  signalType      String            // "positive" | "negative" | "override"
  source          String            // "touch_1_approve" | "touch_1_edit" | "touch_1_upload" etc.
  content         String            // JSON: diff data, original vs edited fields, etc.
  createdAt       DateTime          @default(now())

  @@index([interactionId])
  @@index([signalType])
}

// ────────────────────────────────────────────────────────────
// Phase 5: Transcript Processing & Brief Generation (DATA-02)
// ────────────────────────────────────────────────────────────

model Transcript {
  id              String            @id @default(cuid())
  interactionId   String            @unique
  interaction     InteractionRecord @relation(fields: [interactionId], references: [id])
  rawText         String            // Full transcript text
  additionalNotes String?           // Optional seller-provided meeting notes
  subsector       String            // Selected subsector from SUBSECTORS constant
  // Extracted/reviewed fields (post-seller-edit via field review step)
  customerContext    String @default("")
  businessOutcomes   String @default("")
  constraints        String @default("")
  stakeholders       String @default("")
  timeline           String @default("")
  budget             String @default("")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([interactionId])
  @@index([subsector])
}

model Brief {
  id               String            @id @default(cuid())
  interactionId    String            @unique
  interaction      InteractionRecord @relation(fields: [interactionId], references: [id])
  primaryPillar    String            // Primary Lumenalta solution pillar
  secondaryPillars String            // JSON array of strings
  evidence         String            // Supporting evidence for pillar mapping
  customerContext  String            // Synthesized from all sources
  businessOutcomes String
  constraints      String
  stakeholders     String
  timeline         String
  budget           String
  useCases         String            // JSON: [{name, description, roiOutcomes[], valueHypothesis}]
  roiFraming       String            // JSON: [{useCaseName, roiOutcomes[], valueHypothesis}]
  // Phase 6: Approval tracking
  approvalStatus    String    @default("pending_approval") // "pending_approval" | "approved" | "rejected" | "changes_requested"
  reviewerName      String?   // Name of person who approved/rejected
  approvedAt        DateTime? // Timestamp of approval
  rejectionFeedback String?   // Freeform text on rejection
  workflowRunId     String?   // Mastra workflow run ID for resume operations
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([interactionId])
  @@index([primaryPillar])
}

// ────────────────────────────────────────────────────────────
// Phase 18: pgvector Slide Embeddings (SLIDE-01)
// Stores vector embeddings for slide content similarity search
// ────────────────────────────────────────────────────────────

model SlideEmbedding {
  id                         String   @id @default(cuid())
  templateId                 String
  slideIndex                 Int
  slideObjectId              String?
  contentText                String
  speakerNotes               String?
  embedding                  Unsupported("vector(768)")
  // Single-value columns (backward compat, populated with primary value)
  industry                   String?
  solutionPillar             String?
  persona                    String?
  funnelStage                String?
  contentType                String?
  // Multi-value classification (source of truth)
  classificationJson         String?
  confidence                 Float?
  contentHash                String?
  thumbnailUrl               String?
  thumbnailFetchedAt         DateTime?
  archived                   Boolean  @default(false)
  needsReReview              Boolean  @default(false)
  previousClassificationJson String?
  reviewStatus               String   @default("unreviewed") // "unreviewed" | "approved" | "needs_correction"
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@unique([templateId, contentHash])
  @@index([templateId])
  @@index([archived])
  @@index([reviewStatus])
  @@index([embedding], name: "SlideEmbedding_embedding_idx")
}

// ────────────────────────────────────────────────────────────
// Phase 19: Template Management (TMPL-05/06/07)
// Tracks Google Slides templates used for touch generation
// No FK to SlideEmbedding yet — that comes in Phase 20
// ────────────────────────────────────────────────────────────

model Template {
  id                String    @id @default(cuid())
  name              String
  presentationId    String    @unique
  googleSlidesUrl   String
  touchTypes        String    // JSON array: ["touch_1", "touch_2"]
  accessStatus      String    @default("not_checked") // "accessible" | "not_accessible" | "not_checked"
  lastIngestedAt    DateTime?
  sourceModifiedAt  DateTime?
  slideCount        Int       @default(0)
  ingestionStatus   String    @default("idle") // "idle" | "queued" | "ingesting" | "failed"
  ingestionProgress String?   // JSON: { current, total, phase, skipped }
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([accessStatus])
}

// ────────────────────────────────────────────────────────────
// Phase 22: Encrypted Google Refresh Token Storage (TOKS-01)
// Stores AES-256-GCM encrypted per-user refresh tokens for
// user-delegated Google API access (Drive, Slides, Docs)
// ────────────────────────────────────────────────────────────

model UserGoogleToken {
  id               String    @id @default(cuid())
  userId           String    @unique // Supabase Auth user ID
  email            String // User email for logging/debugging
  encryptedRefresh String // AES-256-GCM encrypted refresh token
  iv               String // Base64-encoded initialization vector
  authTag          String // Base64-encoded GCM authentication tag
  lastUsedAt       DateTime  @default(now())
  isValid          Boolean   @default(true)
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([isValid, lastUsedAt])
  @@index([email])
}

// ────────────────────────────────────────────────────────────
// Phase 27: Encrypted AtlusAI Token Storage (ATLS-01)
// Stores AES-256-GCM encrypted per-user AtlusAI tokens.
// Auth mechanism TBD — uses generic encryptedToken field.
// ────────────────────────────────────────────────────────────

model UserAtlusToken {
  id             String    @id @default(cuid())
  userId         String    @unique // Supabase Auth user ID
  email          String // User email for logging/debugging
  encryptedToken String // AES-256-GCM encrypted token
  iv             String // Base64-encoded initialization vector
  authTag        String // Base64-encoded GCM authentication tag
  clientId       String? // Persisted OAuth client_id to skip re-registration on restart
  lastUsedAt     DateTime  @default(now())
  isValid        Boolean   @default(true)
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([isValid, lastUsedAt])
  @@index([email])
}

// ────────────────────────────────────────────────────────────
// Phase 24: ActionRequired — tracks manual user actions needed
// (e.g., re-auth, share with SA, drive access)
// ────────────────────────────────────────────────────────────

model ActionRequired {
  id           String    @id @default(cuid())
  userId       String?   // null for org-wide actions (e.g., share with SA)
  actionType   String    // "reauth_needed" | "share_with_sa" | "drive_access"
  title        String    // Human-readable title
  description  String    // Detailed guidance for resolution
  resourceId   String?   // Template ID, file ID, etc.
  resourceName String?   // Human-readable resource name
  resolved     Boolean   @default(false)
  resolvedAt   DateTime?
  silenced     Boolean   @default(false)
  seenAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([resolved])
  @@index([userId])
  @@index([actionType])
}
