# Copy this file to .env.dev and .env.prod, then fill in values.
# Usage: make run        (defaults to dev)
#        make run dev    (explicit dev)
#        make run prod   (production)

# Supabase PostgreSQL — pooled connection (port 6543, pgbouncer)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Supabase PostgreSQL — direct connection (port 5432, for migrations/introspection)
DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_TEMPLATE_PRESENTATION_ID=
NODE_ENV=development
MASTRA_PORT=4111

# Source presentation ID for Touch 2 "Meet Lumenalta" intro deck
MEET_LUMENALTA_PRESENTATION_ID=
# Source presentation ID for Touch 3 capability alignment deck
CAPABILITY_DECK_PRESENTATION_ID=

GOOGLE_APPLICATION_CREDENTIALS=./vertex-service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Vertex AI service account JSON for Docker deployment only.
# The container entrypoint writes this to a file and sets GOOGLE_APPLICATION_CREDENTIALS.
# For local dev, use the GOOGLE_APPLICATION_CREDENTIALS file path above instead.
# VERTEX_SERVICE_ACCOUNT_KEY=

# Shared API key for service-to-service auth (web <-> agent)
# Generate with: openssl rand -base64 32
# Must be the same value in both web and agent env files
AGENT_API_KEY=

# Web app origin URL for CORS restriction
WEB_APP_URL=http://localhost:3000

# GCS bucket for cached slide thumbnails (optional)
GCS_THUMBNAIL_BUCKET=
