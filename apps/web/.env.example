AGENT_SERVICE_URL=http://localhost:4111
NODE_ENV=development

# Shared API key for service-to-service auth (web <-> agent)
# Generate with: openssl rand -base64 32
# Must be the same value in both apps/web/.env.local and apps/agent/.env
AGENT_API_KEY=

# Supabase Auth (required -- get from Supabase dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
